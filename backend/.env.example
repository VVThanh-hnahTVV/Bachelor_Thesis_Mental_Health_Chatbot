# MongoDB Atlas (Network Access: allow your IP; Database Access: user with read/write)
MONGO_URI=mongodb+srv://<user>:<password>@mental-health-app.hw7axac.mongodb.net/mental_health?retryWrites=true&w=majority
MONGO_DB_NAME=mental_health

# At least one chat provider should be configured for non-Modal flows
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# PDF ingest (image summary + chunking) — defaults to OpenAI when OPENAI_API_KEY is set
# INGEST_LLM_PROVIDER=openai
# INGEST_OPENAI_MODEL=gpt-4o-mini
# Step 1 PDF parse: openai (API, no local Docling) or docling (local CPU). Defaults to openai when ingest LLM is openai.
# INGEST_PARSE_PROVIDER=openai
# INGEST_PARSE_PAGES_PER_BATCH=8
# Medical RAG chunking (hybrid: header pre-split → batched LLM → word-window fallback)
# INGEST_LLM_CHUNKING=true
# INGEST_CHUNK_BATCH_MAX_WORDS=12000
# INGEST_CHUNK_BATCH_MAX_SECTIONS=35
# INGEST_CHUNK_SIZE_WORDS=512
# INGEST_CHUNK_OVERLAP_WORDS=50
# Bibliographic metadata for ingested PDFs (filename -> title, authors, topics, DOI, ...)
# RAG_DOCUMENT_METADATA_PATH=data/medical/document_metadata.json

# Admin + mental-health web corpus (Qdrant collection separate from PDF RAG)
# BOOTSTRAP_ADMIN_EMAIL=you@example.com
# WEB_QDRANT_COLLECTION=mental_health_web
# WEB_DOCSTORE_PATH=data/medical/docs_db_web
# WEB_QDRANT_PATH=data/medical/qdrant_db
# CRAWL_STAGING_DIR=data/crawl/staging
# WEB_CATALOG_PATH=data/crawl/web_catalog.json
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Embeddings (medical Qdrant + wellness semantic search)
# Omit EMBEDDING_PROVIDER to auto-use OpenAI (text-embedding-3-small) when OPENAI_API_KEY is set
# EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text-v2-moe
OLLAMA_EMBEDDING_DIM=768
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIM=1536

# Local Ollama chat via /v1 (off by default; set true only if you pulled LOCAL_MODEL in Ollama)
ENABLE_LOCAL_CHAT=false
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=llama3.1

# Medical dual-mode (monolith in backend/app/medical)
ENABLE_MEDICAL_MODE=true
TAVILY_API_KEY=
# advanced | basic | fast | ultra-fast (invalid values fall back to advanced)
TAVILY_SEARCH_DEPTH=advanced
# Optional comma-separated domains, e.g. mayoclinic.org,who.int (must be valid hostnames)
# TAVILY_INCLUDE_DOMAINS=
HUGGINGFACE_TOKEN=
ENABLE_TAVILY_SEARCH=true
ENABLE_PUBMED_SEARCH=true
# NCBI E-utilities (email + optional API key from https://www.ncbi.nlm.nih.gov/account/settings/ )
PUBMED_EMAIL=you@example.com
PUBMED_API_KEY=
# When NCBI blocks/rate-limits IP, use Europe PMC (no key required)
PUBMED_EUROPEPMC_FALLBACK=true
# Set false to stop calling NCBI E-utilities (Europe PMC only; stops repeated block warnings)
PUBMED_USE_NCBI=false

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI-compatible fine-tuned / Modal proxy
MODAL_BASE_URL=
MODAL_API_KEY=dummy
MODAL_MODEL=default

# Comma-separated fallback order after primary fails (preferred: local -> openai -> gemini -> groq)
LLM_FALLBACK_CHAIN=groq,openai,gemini

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

JWT_SECRET=generate-a-long-random-string
JWT_EXPIRE_HOURS=168

# Password reset
FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_EXPIRE_MINUTES=60
# Gmail SMTP — bỏ trống để in link reset ra console backend (dev)
MAILDEV_INCOMING_USER=webelearning75@gmail.com
MAILDEV_INCOMING_PASS=

# Chat image uploads (medical mode)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

WELLNESS_ACTIVITY_PLANNER=tool_first
# 1 = LangGraph debug + Thought/Action/Observation trace (tool path) or raw JSON (json path)
# 1 = verbose wellness retrieval trace (vector/keyword hits per activity)
WELLNESS_AGENT_DEBUG=0

# Helios wellness activity vector search (separate from medical PDF RAG)
WELLNESS_QDRANT_COLLECTION=helios_wellness_activities
WELLNESS_SEARCH_TOP_K=5
WELLNESS_SEARCH_MIN_SCORE=0.25
# Show activity buttons after RAG/web when top wellness match score >= this (0–1)
WELLNESS_SUGGESTION_MIN_SCORE=0.4
