# Cấu hình dùng chung cho mọi script. Sửa cho phù hợp rồi `source` tự động.
# Tất cả script đều: source "$(dirname "$0")/config.env"

# AWS
export AWS_REGION="ap-southeast-1"
export CLUSTER_NAME="helios"

# Tên repo ECR
export ECR_BACKEND_REPO="helios/backend"
export ECR_FRONTEND_REPO="helios/frontend"

# Tag image
export IMAGE_TAG="latest"

# Namespace Kubernetes
export NAMESPACE="helios"

# Origin công khai mà người dùng truy cập (browser + CORS).
# - Lần deploy ĐẦU TIÊN chưa có ALB DNS: cứ để trống "" rồi chạy deploy,
#   sau đó lấy ALB DNS (xem README mục "Phase 2") và đặt lại biến này, build+deploy lại frontend.
# - Nếu có domain: đặt "https://app.yourdomain.com".
export PUBLIC_URL="http://k8s-helios-04ec4da8dd-1342208044.ap-southeast-1.elb.amazonaws.com"

# (Tùy chọn) ARN chứng chỉ ACM cho HTTPS. Để trống nếu chạy HTTP.
export ACM_CERT_ARN=""

# Tự suy ra Account ID + registry ECR (không cần sửa).
export AWS_ACCOUNT_ID="$(aws sts get-caller-identity --query Account --output text 2>/dev/null)"
export ECR_REGISTRY="${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
export BACKEND_IMAGE="${ECR_REGISTRY}/${ECR_BACKEND_REPO}:${IMAGE_TAG}"
export FRONTEND_IMAGE="${ECR_REGISTRY}/${ECR_FRONTEND_REPO}:${IMAGE_TAG}"
